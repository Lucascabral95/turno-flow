generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  PENDING               @map("pending")
  CONFIRMED             @map("confirmed")
  CANCELLED_BY_CUSTOMER @map("cancelled_by_customer")
  CANCELLED_BY_BUSINESS @map("cancelled_by_business")
  COMPLETED             @map("completed")
  NO_SHOW               @map("no_show")

  @@map("appointment_status")
}

enum WaitlistStatus {
  WAITING   @map("waiting")
  OFFERED   @map("offered")
  BOOKED    @map("booked")
  EXPIRED   @map("expired")
  CANCELLED @map("cancelled")

  @@map("waitlist_status")
}

enum WaitlistOfferStatus {
  PENDING  @map("pending")
  ACCEPTED @map("accepted")
  EXPIRED  @map("expired")
  REJECTED @map("rejected")

  @@map("waitlist_offer_status")
}

enum NotificationStatus {
  PENDING @map("pending")
  SENT    @map("sent")
  FAILED  @map("failed")

  @@map("notification_status")
}

enum EventOutboxStatus {
  PENDING   @map("pending")
  PUBLISHED @map("published")
  FAILED    @map("failed")

  @@map("event_outbox_status")
}

enum AvailabilityExceptionType {
  BLOCKED       @map("blocked")
  EXTRA_OPENING @map("extra_opening")

  @@map("availability_exception_type")
}

enum CustomerRiskLevel {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")

  @@map("customer_risk_level")
}

enum BusinessMemberRole {
  OWNER        @map("owner")
  RECEPTIONIST @map("receptionist")
  PROFESSIONAL @map("professional")

  @@map("business_member_role")
}

enum BusinessMemberStatus {
  PENDING_INVITE @map("pending_invite")
  ACTIVE         @map("active")
  INACTIVE       @map("inactive")

  @@map("business_member_status")
}

enum CalendarProvider {
  GOOGLE  @map("google")
  OUTLOOK @map("outlook")

  @@map("calendar_provider")
}

enum CalendarConnectionStatus {
  NOT_CONFIGURED @map("not_configured")
  CONNECTED      @map("connected")
  EXPIRED        @map("expired")
  ERROR          @map("error")

  @@map("calendar_connection_status")
}

enum CalendarEventSyncStatus {
  PENDING @map("pending")
  SYNCED  @map("synced")
  DELETED @map("deleted")
  FAILED  @map("failed")

  @@map("calendar_event_sync_status")
}

enum OnboardingStep {
  BUSINESS     @map("business")
  SERVICE      @map("service")
  STAFF        @map("staff")
  AVAILABILITY @map("availability")
  PUBLIC_PAGE  @map("public_page")

  @@map("onboarding_step")
}

enum DepositMode {
  FIXED      @map("fixed")
  PERCENTAGE @map("percentage")

  @@map("deposit_mode")
}

enum AppointmentPaymentType {
  DEPOSIT @map("deposit")

  @@map("appointment_payment_type")
}

enum AppointmentPaymentStatus {
  SUBMITTED @map("submitted")
  CONFIRMED @map("confirmed")
  REJECTED  @map("rejected")
  VOIDED    @map("voided")

  @@map("appointment_payment_status")
}

enum RecurringIntervalUnit {
  DAY   @map("day")
  WEEK  @map("week")
  MONTH @map("month")

  @@map("recurring_interval_unit")
}

enum RecurringSeriesStatus {
  ACTIVE    @map("active")
  PAUSED    @map("paused")
  CANCELLED @map("cancelled")
  COMPLETED @map("completed")

  @@map("recurring_series_status")
}

model User {
  id            String           @id @default(uuid()) @db.Uuid
  email         String           @unique
  passwordHash  String           @map("password_hash")
  name          String
  businesses    Business[]
  refreshTokens RefreshToken[]
  memberships   BusinessMember[]
  auditLogs     AuditLog[]
  customerNotes CustomerNote[]
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  familyId  String    @map("family_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([familyId])
  @@map("refresh_tokens")
}

model Business {
  id                     String                    @id @default(uuid()) @db.Uuid
  ownerId                String                    @map("owner_id") @db.Uuid
  owner                  User                      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name                   String
  slug                   String                    @unique
  timezone               String                    @default("America/Argentina/Buenos_Aires")
  email                  String?
  manualDepositsEnabled  Boolean                   @default(false) @map("manual_deposits_enabled")
  paymentAlias           String?                   @map("payment_alias")
  paymentAccountHolder   String?                   @map("payment_account_holder")
  paymentAccountLabel    String?                   @map("payment_account_label")
  paymentInstructions    String?                   @map("payment_instructions")
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")
  services               Service[]
  staffMembers           StaffMember[]
  availabilityRules      AvailabilityRule[]
  availabilityExceptions AvailabilityException[]
  customers              Customer[]
  appointments           Appointment[]
  waitlistEntries        WaitlistEntry[]
  notifications          Notification[]
  notificationLogs       NotificationLog[]
  appointmentEvents      AppointmentEvent[]
  eventOutbox            EventOutbox[]
  reminderSettings       BusinessReminderSettings?
  metricsDaily           BusinessMetricsDaily[]
  staffMetricsDaily      StaffMemberMetricsDaily[]
  members                BusinessMember[]
  auditLogs              AuditLog[]
  notificationTemplates  NotificationTemplate[]
  calendarConnections    CalendarConnection[]
  calendarEventSyncs        CalendarEventSync[]
  customerNotes             CustomerNote[]
  onboarding                BusinessOnboarding?
  onboardingEvents          BusinessOnboardingEvent[]
  appointmentPayments       AppointmentPayment[]
  recurringSeries           RecurringAppointmentSeries[]

  @@map("businesses")
}

model BusinessOnboarding {
  businessId   String         @id @map("business_id") @db.Uuid
  business     Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  currentStep  OnboardingStep @default(BUSINESS) @map("current_step")
  progressData Json?          @map("progress_data")
  completedAt  DateTime?      @map("completed_at") @db.Timestamptz(3)
  dismissedAt  DateTime?      @map("dismissed_at") @db.Timestamptz(3)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("business_onboarding")
}

model BusinessOnboardingEvent {
  id         String          @id @default(uuid()) @db.Uuid
  businessId String          @map("business_id") @db.Uuid
  business   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  step       OnboardingStep? @map("step")
  eventType  String          @map("event_type")
  metadata   Json?
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([businessId, createdAt])
  @@index([businessId, step, createdAt])
  @@map("business_onboarding_events")
}

model BusinessMember {
  id              String               @id @default(uuid()) @db.Uuid
  businessId      String               @map("business_id") @db.Uuid
  business        Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId          String?              @map("user_id") @db.Uuid
  user            User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffMemberId   String?              @map("staff_member_id") @db.Uuid
  staffMember     StaffMember?         @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  role            BusinessMemberRole
  status          BusinessMemberStatus @default(ACTIVE)
  inviteEmail     String?              @map("invite_email")
  inviteTokenHash String?              @map("invite_token_hash")
  inviteExpiresAt DateTime?            @map("invite_expires_at") @db.Timestamptz
  active          Boolean              @default(true)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@unique([businessId, userId])
  @@index([businessId, role])
  @@index([userId, active])
  @@index([businessId, inviteEmail])
  @@map("business_members")
}

model StaffMember {
  id                   String                    @id @default(uuid()) @db.Uuid
  businessId           String                    @map("business_id") @db.Uuid
  business             Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name                 String
  email                String?
  active               Boolean                   @default(true)
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  appointments         Appointment[]
  availabilityRules    AvailabilityRule[]
  availabilityExceptions AvailabilityException[]
  memberships          BusinessMember[]
  calendarConnections  CalendarConnection[]
  serviceAssignments   ServiceStaffMember[]
  metricsDaily         StaffMemberMetricsDaily[]
  recurringSeries      RecurringAppointmentSeries[]

  @@index([businessId])
  @@map("staff_members")
}

model Service {
  id                 String               @id @default(uuid()) @db.Uuid
  businessId         String               @map("business_id") @db.Uuid
  business           Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name               String
  durationMinutes    Int                  @map("duration_minutes")
  priceCents         Int                  @default(0) @map("price_cents")
  bufferMinutes      Int                  @default(0) @map("buffer_minutes")
  depositEnabled     Boolean              @default(false) @map("deposit_enabled")
  depositMode        DepositMode          @default(FIXED) @map("deposit_mode")
  depositAmountCents Int                  @default(0) @map("deposit_amount_cents")
  depositPercentage  Int                  @default(0) @map("deposit_percentage")
  depositDescription String?              @map("deposit_description")
  active             Boolean              @default(true)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  appointments       Appointment[]
  waitlistEntries    WaitlistEntry[]
  staffAssignments   ServiceStaffMember[]
  recurringSeries    RecurringAppointmentSeries[]

  @@index([businessId])
  @@map("services")
}

model ServiceStaffMember {
  id            String      @id @default(uuid()) @db.Uuid
  serviceId     String      @map("service_id") @db.Uuid
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staffMemberId String      @map("staff_member_id") @db.Uuid
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([serviceId, staffMemberId])
  @@map("service_staff_members")
}

model AvailabilityRule {
  id            String      @id @default(uuid()) @db.Uuid
  businessId    String      @map("business_id") @db.Uuid
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffMemberId String      @map("staff_member_id") @db.Uuid
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  weekday       Int
  startTime     String      @map("start_time")
  endTime       String      @map("end_time")
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([businessId, weekday])
  @@map("availability_rules")
}

model AvailabilityException {
  id            String                    @id @default(uuid()) @db.Uuid
  businessId    String                    @map("business_id") @db.Uuid
  business      Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffMemberId String?                   @map("staff_member_id") @db.Uuid
  staffMember   StaffMember?              @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  date          DateTime                  @db.Date
  startTime     String                    @map("start_time")
  endTime       String                    @map("end_time")
  type          AvailabilityExceptionType
  reason        String?
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  @@index([businessId, date])
  @@index([staffMemberId, date])
  @@map("availability_exceptions")
}

model Customer {
  id                    String            @id @default(uuid()) @db.Uuid
  businessId            String            @map("business_id") @db.Uuid
  business              Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name                  String
  email                 String
  phone                 String?
  noShowCount           Int               @default(0) @map("no_show_count")
  completedAppointments Int               @default(0) @map("completed_appointments")
  totalAppointments     Int               @default(0) @map("total_appointments")
  riskLevel             CustomerRiskLevel @default(LOW) @map("risk_level")
  riskScore             Int               @default(0) @map("risk_score")
  requiresDeposit       Boolean           @default(false) @map("requires_deposit")
  lastRiskCalculatedAt  DateTime?         @map("last_risk_calculated_at") @db.Timestamptz(3)
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  appointments          Appointment[]
  waitlistEntries       WaitlistEntry[]
  notifications         Notification[]
  notes                 CustomerNote[]
  appointmentPayments   AppointmentPayment[]
  recurringSeries       RecurringAppointmentSeries[]

  @@unique([businessId, email])
  @@index([businessId, riskLevel, riskScore])
  @@map("customers")
}

model CustomerNote {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId     String?  @map("user_id") @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  content    String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([businessId, customerId, createdAt])
  @@index([userId, createdAt])
  @@map("customer_notes")
}

model Appointment {
  id                  String             @id @default(uuid()) @db.Uuid
  businessId          String             @map("business_id") @db.Uuid
  business            Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceId           String             @map("service_id") @db.Uuid
  service             Service            @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staffMemberId       String             @map("staff_member_id") @db.Uuid
  staffMember         StaffMember        @relation(fields: [staffMemberId], references: [id], onDelete: Restrict)
  customerId          String             @map("customer_id") @db.Uuid
  customer            Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  startsAt            DateTime           @map("starts_at") @db.Timestamptz(3)
  endsAt              DateTime           @map("ends_at") @db.Timestamptz(3)
  status              AppointmentStatus  @default(CONFIRMED)
  cancellationToken   String             @unique @map("cancellation_token")
  attendanceAlertedAt  DateTime?                   @map("attendance_alerted_at") @db.Timestamptz(3)
  recurringSeriesId    String?                     @map("recurring_series_id") @db.Uuid
  recurringSeries      RecurringAppointmentSeries? @relation(fields: [recurringSeriesId], references: [id], onDelete: SetNull)
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")
  notifications        Notification[]
  notificationLogs     NotificationLog[]
  appointmentEvents    AppointmentEvent[]
  waitlistOffers       WaitlistOffer[]
  calendarEventSyncs   CalendarEventSync[]
  payments             AppointmentPayment[]

  @@index([businessId, startsAt])
  @@index([staffMemberId, startsAt])
  @@index([status, endsAt, attendanceAlertedAt])
  @@index([recurringSeriesId, status, startsAt])
  @@map("appointments")
}

model AppointmentPayment {
  id                String                   @id @default(uuid()) @db.Uuid
  businessId        String                   @map("business_id") @db.Uuid
  business          Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointmentId     String                   @map("appointment_id") @db.Uuid
  appointment       Appointment              @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customerId        String                   @map("customer_id") @db.Uuid
  customer          Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type              AppointmentPaymentType   @default(DEPOSIT)
  status            AppointmentPaymentStatus @default(SUBMITTED)
  amountCents       Int                      @map("amount_cents")
  currency          String                   @default("ARS")
  reference         String?
  customerNote      String?                  @map("customer_note")
  internalNote      String?                  @map("internal_note")
  submittedAt       DateTime                 @default(now()) @map("submitted_at") @db.Timestamptz(3)
  confirmedAt       DateTime?                @map("confirmed_at") @db.Timestamptz(3)
  rejectedAt        DateTime?                @map("rejected_at") @db.Timestamptz(3)
  voidedAt          DateTime?                @map("voided_at") @db.Timestamptz(3)
  confirmedByUserId String?                  @map("confirmed_by_user_id") @db.Uuid
  rejectedByUserId  String?                  @map("rejected_by_user_id") @db.Uuid
  voidedByUserId    String?                  @map("voided_by_user_id") @db.Uuid
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  @@index([businessId, status, submittedAt])
  @@index([appointmentId, status])
  @@index([customerId, status])
  @@map("appointment_payments")
}

model WaitlistEntry {
  id                 String           @id @default(uuid()) @db.Uuid
  businessId         String           @map("business_id") @db.Uuid
  business           Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceId          String           @map("service_id") @db.Uuid
  service            Service          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  customerId         String           @map("customer_id") @db.Uuid
  customer           Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  preferredDateStart DateTime         @map("preferred_date_start") @db.Date
  preferredDateEnd   DateTime         @map("preferred_date_end") @db.Date
  earliestTime       String?          @map("earliest_time")
  latestTime         String?          @map("latest_time")
  status             WaitlistStatus   @default(WAITING)
  priorityScore      Int              @default(0) @map("priority_score")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  offers             WaitlistOffer[]
  notificationLogs   NotificationLog[]

  @@index([businessId, serviceId, status])
  @@map("waitlist_entries")
}

model WaitlistOffer {
  id              String              @id @default(uuid()) @db.Uuid
  waitlistEntryId String              @map("waitlist_entry_id") @db.Uuid
  waitlistEntry   WaitlistEntry       @relation(fields: [waitlistEntryId], references: [id], onDelete: Cascade)
  appointmentId   String              @map("appointment_id") @db.Uuid
  appointment     Appointment         @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  token           String              @unique
  status          WaitlistOfferStatus @default(PENDING)
  expiresAt       DateTime            @map("expires_at") @db.Timestamptz(3)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([status, expiresAt])
  @@map("waitlist_offers")
}

model BusinessReminderSettings {
  businessId    String   @id @map("business_id") @db.Uuid
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  enabled       Boolean  @default(true)
  offsetMinutes Int      @default(1440) @map("offset_minutes")
  channel       String   @default("mock")
  template      String   @default("appointment_reminder_24h")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("business_reminder_settings")
}

model NotificationTemplate {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  key        String
  name       String
  subject    String
  body       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([businessId, key])
  @@index([businessId, active])
  @@map("notification_templates")
}

model CalendarConnection {
  id                    String                   @id @default(uuid()) @db.Uuid
  businessId            String                   @map("business_id") @db.Uuid
  business              Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffMemberId         String?                  @map("staff_member_id") @db.Uuid
  staffMember           StaffMember?             @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  provider              CalendarProvider
  status                CalendarConnectionStatus @default(NOT_CONFIGURED)
  accountEmail          String?                  @map("account_email")
  externalCalendarId    String?                  @map("external_calendar_id")
  accessTokenEncrypted  String?                  @map("access_token_encrypted")
  refreshTokenEncrypted String?                  @map("refresh_token_encrypted")
  expiresAt             DateTime?                @map("expires_at") @db.Timestamptz(3)
  lastSyncedAt          DateTime?                @map("last_synced_at") @db.Timestamptz(3)
  lastError             String?                  @map("last_error")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")
  eventSyncs            CalendarEventSync[]

  @@unique([businessId, provider])
  @@index([businessId, provider, status])
  @@map("calendar_connections")
}

model CalendarEventSync {
  id                   String                  @id @default(uuid()) @db.Uuid
  businessId           String                  @map("business_id") @db.Uuid
  business             Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointmentId        String                  @map("appointment_id") @db.Uuid
  appointment          Appointment             @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  calendarConnectionId String                  @map("calendar_connection_id") @db.Uuid
  calendarConnection   CalendarConnection      @relation(fields: [calendarConnectionId], references: [id], onDelete: Cascade)
  googleEventId        String?                 @map("google_event_id")
  status               CalendarEventSyncStatus @default(PENDING)
  lastError            String?                 @map("last_error")
  lastSyncedAt         DateTime?               @map("last_synced_at") @db.Timestamptz(3)
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  @@unique([appointmentId, calendarConnectionId])
  @@index([businessId, status])
  @@index([calendarConnectionId, status])
  @@map("calendar_event_syncs")
}

model Notification {
  id            String             @id @default(uuid()) @db.Uuid
  businessId    String             @map("business_id") @db.Uuid
  business      Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointmentId String?            @map("appointment_id") @db.Uuid
  appointment   Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customerId    String             @map("customer_id") @db.Uuid
  customer      Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel       String             @default("mock")
  email         String
  template      String
  status        NotificationStatus @default(PENDING)
  dueAt         DateTime           @map("due_at") @db.Timestamptz(3)
  attempts      Int                @default(0)
  lastError     String?            @map("last_error")
  nextAttemptAt DateTime?          @map("next_attempt_at") @db.Timestamptz(3)
  sentAt        DateTime?          @map("sent_at") @db.Timestamptz(3)
  payload       Json
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  logs          NotificationLog[]

  @@index([businessId, status, dueAt])
  @@index([status, nextAttemptAt])
  @@index([appointmentId])
  @@map("notifications")
}

model NotificationLog {
  id              String             @id @default(uuid()) @db.Uuid
  businessId      String             @map("business_id") @db.Uuid
  business        Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  notificationId  String?            @map("notification_id") @db.Uuid
  notification    Notification?      @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  appointmentId   String?            @map("appointment_id") @db.Uuid
  appointment     Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  waitlistEntryId String?            @map("waitlist_entry_id") @db.Uuid
  waitlistEntry   WaitlistEntry?     @relation(fields: [waitlistEntryId], references: [id], onDelete: SetNull)
  email           String
  template        String
  status          NotificationStatus @default(PENDING)
  attempts        Int                @default(0)
  lastError       String?            @map("last_error")
  sentAt          DateTime?          @map("sent_at") @db.Timestamptz(3)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([businessId, status])
  @@index([notificationId])
  @@map("notification_logs")
}

model AppointmentEvent {
  id            String      @id @default(uuid()) @db.Uuid
  businessId    String      @map("business_id") @db.Uuid
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointmentId String      @map("appointment_id") @db.Uuid
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  eventType     String      @map("event_type")
  metadata      Json
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([businessId, appointmentId])
  @@map("appointment_events")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String?  @map("user_id") @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entity     String
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  metadata   Json?
  requestId  String?  @map("request_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([businessId, createdAt])
  @@index([businessId, entity, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model EventOutbox {
  id            String            @id @default(uuid()) @db.Uuid
  type          String
  version       Int
  businessId    String            @map("business_id") @db.Uuid
  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  aggregateId   String            @map("aggregate_id") @db.Uuid
  routingKey    String            @map("routing_key")
  payload       Json
  correlationId String?           @map("correlation_id")
  status        EventOutboxStatus @default(PENDING)
  attempts      Int               @default(0)
  lastError     String?           @map("last_error")
  publishedAt   DateTime?         @map("published_at") @db.Timestamptz(3)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("outbox_events")
}

model BusinessMetricsDaily {
  businessId            String   @map("business_id") @db.Uuid
  business              Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date                  DateTime @db.Date
  totalAppointments     Int      @default(0) @map("total_appointments")
  activeAppointments    Int      @default(0) @map("active_appointments")
  completedAppointments Int      @default(0) @map("completed_appointments")
  cancelledAppointments Int      @default(0) @map("cancelled_appointments")
  noShowAppointments    Int      @default(0) @map("no_show_appointments")
  estimatedRevenueCents Int      @default(0) @map("estimated_revenue_cents")
  lostRevenueCents      Int      @default(0) @map("lost_revenue_cents")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@id([businessId, date])
  @@index([businessId, date])
  @@map("business_metrics_daily")
}

model StaffMemberMetricsDaily {
  businessId            String      @map("business_id") @db.Uuid
  business              Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffMemberId         String      @map("staff_member_id") @db.Uuid
  staffMember           StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  date                  DateTime    @db.Date
  totalAppointments     Int         @default(0) @map("total_appointments")
  completedAppointments Int         @default(0) @map("completed_appointments")
  cancelledAppointments Int         @default(0) @map("cancelled_appointments")
  noShowAppointments    Int         @default(0) @map("no_show_appointments")
  estimatedRevenueCents Int         @default(0) @map("estimated_revenue_cents")
  occupancyMinutes      Int         @default(0) @map("occupancy_minutes")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  @@id([businessId, staffMemberId, date])
  @@index([businessId, staffMemberId, date])
  @@map("staff_member_metrics_daily")
}

model RecurringAppointmentSeries {
  id                 String                @id @default(uuid()) @db.Uuid
  businessId         String                @map("business_id") @db.Uuid
  business           Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId         String                @map("customer_id") @db.Uuid
  customer           Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  serviceId          String                @map("service_id") @db.Uuid
  service            Service               @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staffMemberId      String                @map("staff_member_id") @db.Uuid
  staffMember        StaffMember           @relation(fields: [staffMemberId], references: [id], onDelete: Restrict)
  intervalValue      Int                   @map("interval_value")
  intervalUnit       RecurringIntervalUnit @map("interval_unit")
  nextOccurrenceAt   DateTime              @map("next_occurrence_at") @db.Timestamptz(3)
  advanceNoticeDays  Int                   @default(7) @map("advance_notice_days")
  status             RecurringSeriesStatus @default(ACTIVE) @map("status")
  maxOccurrences     Int?                  @map("max_occurrences")
  occurrencesCreated Int                   @default(0) @map("occurrences_created")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  appointments       Appointment[]

  @@index([businessId, status, nextOccurrenceAt])
  @@map("recurring_appointment_series")
}

model ProcessedEvent {
  eventId     String   @id @map("event_id") @db.Uuid
  type        String
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(3)

  @@map("processed_events")
}
